+    def parse_classes(self, classes: Any) -> Optional[List[int]]:
+        """
+        Parse class IDs from a launch parameter.
+
+        Accepts values such as 0, "0", "0,2", or [0, 2].
+        """
+
+        if classes is None:
+            return None
+
+        parsed_classes = classes
+        if isinstance(classes, str):
+            if not classes.strip():
+                return None
+
+            try:
+                parsed_classes = ast.literal_eval(classes)
+            except (SyntaxError, ValueError):
+                parsed_classes = classes
+
+        if isinstance(parsed_classes, int):
+            class_ids = [parsed_classes]
+        elif isinstance(parsed_classes, str):
+            class_ids = [
+                int(class_id.strip())
+                for class_id in parsed_classes.split(",")
+                if class_id.strip()
+            ]
+        elif isinstance(parsed_classes, (list, tuple)):
+            class_ids = [int(class_id) for class_id in parsed_classes]
+        else:
+            raise ValueError(f"expected class IDs, got '{classes}'")
+
+        return class_ids or None
+
